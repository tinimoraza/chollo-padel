{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.huntpadel.com" }],
      "destination": "https://huntpadel.com/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/check-alerts",
      "schedule": "0 9 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ]
}
