{
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/check-alerts",
      "schedule": "0 9 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ]
}
